# Copy to .kamal/secrets and fill in. NEVER commit .kamal/secrets (it's gitignored).
# Kamal reads these at deploy time. Values can be pulled from a password manager,
# e.g.:  DATABASE_URL=$(op read "op://Prod/lago/database_url")
#
# Registry
KAMAL_REGISTRY_PASSWORD=

# Database / cache
DATABASE_URL=postgresql://lago:CHANGE_ME@DB_HOST:5432/lago?search_path=public
REDIS_URL=redis://REDIS_HOST:6379
POSTGRES_PASSWORD=CHANGE_ME

# Rails / Lago crypto material (generate strong values; never reuse the demos)
#   SECRET_KEY_BASE:                 openssl rand -hex 64
#   LAGO_RSA_PRIVATE_KEY:            openssl genrsa 2048 | openssl base64 -A
#   LAGO_ENCRYPTION_*:               openssl rand -hex 16
SECRET_KEY_BASE=
LAGO_RSA_PRIVATE_KEY=
LAGO_ENCRYPTION_PRIMARY_KEY=
LAGO_ENCRYPTION_DETERMINISTIC_KEY=
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=
