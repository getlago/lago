# BFP Lago local environment examples.
#
# Copy the API block to api/.env and the Front block to front/.env.
# Generate real local secrets before running a shared environment:
#
#   openssl rand -hex 64
#   openssl rand -hex 32
#   openssl genrsa 2048 > api/config/keys/private.pem

### API: api/.env

DATABASE_URL=postgresql://lago:changeme@127.0.0.1:5432/lago
DATABASE_POOL=5

REDIS_URL=redis://127.0.0.1:6379/0
LAGO_REDIS_CACHE_URL=redis://127.0.0.1:6379/3
LAGO_REDIS_CACHE_DB=3

LAGO_API_URL=http://localhost:3000
LAGO_FRONT_URL=http://localhost:5173
LAGO_FROM_EMAIL=noreply@bfp.local

LAGO_DISABLE_SEGMENT=true
LAGO_DISABLE_PDF_GENERATION=true
LAGO_CLICKHOUSE_ENABLED=
LAGO_CLICKHOUSE_MIGRATIONS_ENABLED=
LAGO_USE_AWS_S3=false

LAGO_CREATE_ORG=true
LAGO_ORG_USER_EMAIL=admin@bfp.local
LAGO_ORG_USER_PASSWORD=password
LAGO_ORG_NAME=BFP Local
LAGO_ORG_API_KEY=lago_key_bfp_local

SECRET_KEY_BASE=replace-with-openssl-rand-hex-64
LAGO_ENCRYPTION_PRIMARY_KEY=replace-with-openssl-rand-hex-32
LAGO_ENCRYPTION_DETERMINISTIC_KEY=replace-with-openssl-rand-hex-32
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=replace-with-openssl-rand-hex-32

# Prefer api/config/keys/private.pem for local dev.
# Alternative: set base64-encoded PEM here.
LAGO_RSA_PRIVATE_KEY=

### Front: front/.env

API_URL=http://localhost:3000
APP_ENV=development
CODEGEN_API=http://localhost:3000/graphql
CYPRESS_APP_URL=http://localhost:5173

LAGO_DOMAIN=
LAGO_OAUTH_PROXY_URL=
LAGO_DISABLE_SIGNUP=
LAGO_DISABLE_PDF_GENERATION=true
LAGO_API_PROXY_TARGET=

NANGO_PUBLIC_KEY=
SENTRY_DSN=
LAGO_SUPERSET_URL=
